# Copy to .env and fill in. .env is gitignored.

# --- AI classification ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Web app (required) ---
INVITE_CODE=pick-something-friends-only      # friends enter this to create a profile
ADMIN_PASSWORD=pick-a-strong-admin-password  # Basic-Auth password for /admin (user: admin)


# --- Postgres ---
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=craigslist

# --- Notifications ---
# ntfy: nothing required for the public server (https://ntfy.sh).
# Self-host? point at it here:
# NTFY_SERVER=https://ntfy.example.com

# Twilio (only needed if any user picks the "sms" channel)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1XXXXXXXXXX
